---
# 상위 디렉토리의 설정을 상속받지 않고 독립적인 규칙을 적용합니다.
InheritParentConfig: false

# 주요 검사 항목: 버그 예방 및 성능 최적화 중심
# 가독성 저해 및 오탐 가능성이 높은 특정 항목은 제외하였습니다.
Checks: >
  bugprone-*,
  performance-*,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  modernize-use-nullptr,
  modernize-use-override

# 네이밍 컨벤션 및 매직 넘버 등 스타일 관련 검사는
# 프로젝트 가이드라인과의 유연성을 위해 Checks 리스트에서 제외되었습니다.
---
